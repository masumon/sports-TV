APP_NAME=Global Sports Live TV API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
APP_HOST=0.0.0.0
APP_PORT=8000

# Production এ PostgreSQL URL ব্যবহার করুন
# উদাহরণ: postgresql+psycopg://user:password@localhost:5432/sports_tv
DATABASE_URL=
SQLITE_FALLBACK_URL=sqlite:///./sports_tv.db

JWT_SECRET_KEY=change-this-to-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ADMIN_EMAIL=admin@gstv.local
ADMIN_PASSWORD=Admin12345!
ADMIN_FULL_NAME=Platform Admin

# Comma-separated origins, no trailing slash. Include every frontend URL (local + Vercel).
# Example: http://localhost:3000,https://sports-tv-lovat.vercel.app
CORS_ORIGINS=http://localhost:3000
SCRAPER_SOURCE_URL=https://iptv-org.github.io/iptv/categories/sports.m3u
AUTO_SYNC_CHANNELS_ON_STARTUP=false

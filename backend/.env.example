# =============================================================================
# Global Sports Live TV — Backend (FastAPI) — TEMPLATE ONLY
# কপি করে .env বানান:  cp .env.example .env
# Never commit .env. Production এ শক্তish JWT, নিরাপদ admin পাসওয়ার্ড, সঠিক CORS।
# =============================================================================

# --- App ---
APP_NAME=Global Sports Live TV API
# development | production (production এ placeholder JWT নিষিদ্ধ)
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database ---
# খালি রাখলে sqlite_fallback_url (সাধারণত ./sports_tv.db)। প্রোডে Neon/Render Postgres:
# postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=
SQLITE_FALLBACK_URL=sqlite:///./sports_tv.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Auth (JWT) ---
# openssl rand -hex 32 এ জেনারেট করতে পারেন
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Seeded admin (first run). Production এ এগুলো বদলান ---
ADMIN_EMAIL=admin@gstv.tv
ADMIN_PASSWORD=Admin12345!
ADMIN_FULL_NAME=Platform Admin

# --- CORS: comma, no trailing slash. Local + Vercel URL সবুজ যুক্ত করুন ---
CORS_ORIGINS=http://localhost:3000

# --- M3U / sync ---
SCRAPER_SOURCE_URL=https://iptv-org.github.io/iptv/categories/sports.m3u
# স্টার্টআপে যদি চ্যানেল 0 হয় তবে একবার sync (ঐচ্ছিক)
AUTO_SYNC_CHANNELS_ON_STARTUP=false
# POST /admin/channels/sync রেট লিমিট (সেকেন্ড, প্রসেস-লোকাল)
SYNC_RATE_LIMIT_SECONDS=60
# ব্যাকগ্রাউন্ড M3U sync (0 = বন্ধ). 30 মিনিটে একবার: 30
SCHEDULED_SYNC_INTERVAL_MINUTES=0

# --- Redis (ঐচ্ছিক) — GET /channels, /live-scores ক্যাশ। না দিলে in-memory fallback
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=rediss://:password@host:6379
REDIS_URL=
# ক্যাশ TTL (সেকেন্ড) — ৫–১০ মিনিটের মধ্যে
CACHE_TTL_SECONDS=300

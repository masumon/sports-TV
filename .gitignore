# Diagnostic scripts that must never contain credentials
check_neon.py

# =========================
# Global Monorepo Ignore
# =========================

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example
!.env.local.example

# =========================
# Node.js / Frontend
# =========================
node_modules/
.next/
out/
dist/
coverage/
*.tsbuildinfo

# PWA — generated by @ducanh2912/next-pwa during `next build` (Vercel regenerates)
frontend/public/sw.js
frontend/public/workbox-*.js
frontend/public/fallback-*.js

# =========================
# Python / Backend
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
# Only root-level Python/distutils "lib" build dirs — not frontend/src/lib
/lib/
/lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# Python testing / tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/

# Local database files
*.sqlite
*.sqlite3
*.db

# =========================
# Build Artifacts
# =========================
tmp/
temp/
*.pid

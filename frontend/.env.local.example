# =============================================================================
# Global Sports Live TV — Next.js — TEMPLATE ONLY
# কপি:  cp .env.local.example .env.local   (Windows: copy)
# Vercel ড্যাশবোর্ডে একই variable গুলো যোগ করুন (NEXT_PUBLIC_* = ব্রাউজারে যায়)
# =============================================================================

# API বেস: শুধু অরিজিন, trailing slash নেই, path এ /api/v1 যোগা হয় কোডে
#
# Vercel (প্রোড) — সরাসরি Render API (CORS-এ Vercel URL Render এ যুক্ত করতে হবে):
#   NEXT_PUBLIC_API_BASE_URL=https://gstv-backend.onrender.com
# অথবা same-origin rewrites: NEXT_PUBLIC_API_BASE_URL=/api এবং BACKEND_URL=...
# যদি ঘরানো না করেন, default = /api
#
# লোকাল: সরাসরি ব্যাকএন্ড
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# OG / metadata / sitemap (নিজের Vercel ডোমেইন, trailing slash নেই)
# প্রোড: https://sports-tv-lovat.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Render backend origin for the Next.js proxy rewrite (server-side only, NOT NEXT_PUBLIC_).
# Vercel ড্যাশবোর্ডে এই variable সেট করুন — Render service URL (trailing slash বা /api ছাড়া)।
# যদি না দেন, next.config.ts এর production default ব্যবহার হবে।
# BACKEND_URL=https://gstv-backend.onrender.com
